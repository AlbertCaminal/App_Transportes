# Copia a .env.local y rellena (no subas .env* al repositorio con secretos).
# Variables EXPO_PUBLIC_* se inyectan en el bundle del cliente — nunca pongas API keys privadas aquí.

# Cuenta Expo (opcional, para EAS / builds en la nube)
# EXPO_ACCOUNT_SLUG=tu-usuario-expo

# ID del proyecto EAS (se genera con: npx eas-cli init)
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ejemplo: URL del backend cuando exista (solo si es público y seguro exponerla)
# EXPO_PUBLIC_API_URL=https://api.example.com

# --- Firebase (Firestore + Auth) — copia desde Firebase Console → Configuración del proyecto → Tus apps ---
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Google Sign-In (Firebase Auth) ---
# Crea credenciales OAuth 2.0 en Google Cloud Console (https://console.cloud.google.com/apis/credentials)
# para el mismo proyecto que Firebase. Necesitas un Client ID por plataforma.
# Si todas están vacías, la pantalla de Login muestra Google deshabilitado y solo permite continuar como invitado.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com
# (Opcional) Para Expo Go, usa el Client ID tipo "Expo" registrado con tu cuenta:
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com

# --- Observabilidad (opcional) ---
# Si está vacío, Sentry queda deshabilitado sin errores.
# EXPO_PUBLIC_SENTRY_DSN=
