rules_version = '2';

// Despliega con: firebase deploy --only firestore:rules
// O pega estas reglas en Firebase Console → Firestore → Reglas

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: solo el propio UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- TODO cuando definamos el modelo real en código y en Firestore ---
    // Añadir aquí bloques `match` para colecciones como `requests`, `services`,
    // `routes`, `ratings`, etc., con reglas por rol (cliente vs transportista) y
    // ownership (ej. resource.data.ownerId == request.auth.uid). Publicar siempre
    // en consola o con `firebase deploy --only firestore:rules`, y revisar tests
    // simuladores si los hay.
    //
    // Envíos (ejemplo antiguo): ajustar según roles antes de descomentar.
    // match /shipments/{id} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
