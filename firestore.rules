rules_version = '2';

// Despliega con: firebase deploy --only firestore:rules
// O pega estas reglas en Firebase Console → Firestore → Reglas

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: solo el propio UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Envíos (ejemplo futuro): ajusta según roles (cliente / transportista)
    // match /shipments/{id} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
